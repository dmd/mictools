#!/bin/bash

# Read the password interactively so it never appears on the command line
# (command-line args are world-readable via ps / /proc/PID/cmdline).
if [ $# -ne 0 ]; then
    echo "Do not pass the password as an argument; it would be visible to other" >&2
    echo "users via 'ps'. You will be prompted for it instead." >&2
    exit 1
fi

# Enforce basic length and complexity requirements. Re-prompt until satisfied.
validate_password() {
    local pw=$1
    local errors=()
    [ ${#pw} -lt 12 ]               && errors+=("at least 12 characters")
    [[ "$pw" == *[[:lower:]]* ]]    || errors+=("a lowercase letter")
    [[ "$pw" == *[[:upper:]]* ]]    || errors+=("an uppercase letter")
    [[ "$pw" == *[[:digit:]]* ]]    || errors+=("a digit")
    [[ "$pw" == *[^[:alnum:]]* ]]   || errors+=("a special character")

    if [ ${#errors[@]} -ne 0 ]; then
        echo "Password does not meet the requirements. It must contain:" >&2
        local e
        for e in "${errors[@]}"; do
            echo "  - $e" >&2
        done
        return 1
    fi
    return 0
}

while true; do
    read -r -s -p "Enter a password for RStudio: " password; echo
    if ! validate_password "$password"; then
        continue
    fi
    read -r -s -p "Re-enter the password: " password2; echo
    if [ "$password" != "$password2" ]; then
        echo "Passwords do not match; try again." >&2
        continue
    fi
    unset password2
    break
done

# Select the container image from the name this script was invoked as, so
# rstudio-runner-custom can simply be a symlink to rstudio-runner.
case "$(basename "$0")" in
    *-custom) image=/data/singularity-images/rstudio-4.4.3-custom.sif ;;
    *)        image=/data/singularity-images/rstudio_4.2.sif ;;
esac

mkdir -p run var-lib-rstudio-server
printf 'provider=sqlite\ndirectory=/var/lib/rstudio-server\n' > database.conf

# RStudio Server (open source) can't terminate TLS itself, so run rserver on a
# localhost-only plaintext port and put a TLS-terminating proxy (socat) in front
# of it, reusing the same certificate as the Jupyter runner. socat forwards raw
# bytes, so RStudio's websocket connections pass through unchanged.
CERT="/home/ddrucker/mictools/everything-mickey.pem"
port=$(shuf -i 30000-50000 -n 1)       # public HTTPS port (TLS terminated by socat)
backend=$(shuf -i 30000-50000 -n 1)    # rserver's plaintext port, bound to localhost
while [ "$backend" = "$port" ]; do backend=$(shuf -i 30000-50000 -n 1); done

# Advertise the name the certificate is issued for, so the URL is reachable and
# TLS validates. Derived from the cert's CN.
fqdn=$(openssl x509 -in "$CERT" -noout -subject -nameopt multiline \
    | awk -F' = ' '/commonName/{print $2}')

# Run the proxy and server under job control (set -m) so each gets its own
# process group. A Ctrl-C in the terminal then reaches only this script, which
# shuts them down with SIGTERM. If the terminal's SIGINT reaches rserver
# directly it dies with "bus error (core dumped)"; SIGTERM is clean.
set -m
cleanup() {
    trap - INT TERM EXIT
    [ -n "$rserver_pid" ] && kill -TERM -"$rserver_pid" 2>/dev/null
    [ -n "$socat_pid" ]   && kill -TERM -"$socat_pid"   2>/dev/null
    wait 2>/dev/null
}
trap cleanup INT TERM EXIT

socat OPENSSL-LISTEN:$port,cert=$CERT,verify=0,reuseaddr,fork TCP:127.0.0.1:$backend &
socat_pid=$!

echo Connect to https://$fqdn:$port/

APPTAINERENV_OMP_NUM_THREADS=1 PASSWORD="$password" singularity exec \
   -B /data --bind run:/run,var-lib-rstudio-server:/var/lib/rstudio-server,database.conf:/etc/rstudio/database.conf \
   "$image" \
   /usr/lib/rstudio-server/bin/rserver --www-port $backend --www-address 127.0.0.1 --auth-none=0 --auth-pam-helper-path=pam-helper --server-user=$(whoami) &
rserver_pid=$!

wait "$rserver_pid"
